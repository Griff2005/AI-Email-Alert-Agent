# Agent mailbox credentials
AGENT_EMAIL=agent@placeholder.com
AGENT_EMAIL_PASSWORD=PLACEHOLDER

# IMAP settings (inbound email)
IMAP_HOST=imap.placeholder.com
IMAP_PORT=993

# SMTP settings (outbound email)
SMTP_HOST=smtp.placeholder.com
SMTP_PORT=587

# Demo safety: all outbound email is redirected to this address only
DEMO_RECIPIENT_EMAIL=demo@placeholder.com
DEMO_MODE=true

# Claude model for AI classification and extraction
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Flask settings
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Database path (relative to project root)
DATABASE_PATH=data/agent.db

# Claude response cache (set to false to disable)
CLAUDE_CACHE_ENABLED=true
CLAUDE_CACHE_PATH=data/claude_cache.json

# Scheduler interval in seconds (default: 300 = 5 minutes)
FOLLOWUP_CHECK_INTERVAL=300
